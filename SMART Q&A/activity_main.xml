<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:padding="32dp" android:background="#F0F4FF">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Smart Q&amp;A" android:textSize="34sp"
        android:textStyle="bold" android:textColor="#3F51B5"
        android:layout_marginBottom="8dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Ask. Upvote. Learn." android:textSize="15sp"
        android:textColor="#757575" android:layout_marginBottom="48dp"/>

    <Button android:id="@+id/btnStudent" android:layout_width="match_parent"
        android:layout_height="56dp" android:text="I'm a Student"
        android:textSize="16sp" android:backgroundTint="#3F51B5"
        android:layout_marginBottom="16dp"/>

    <Button android:id="@+id/btnFaculty" android:layout_width="match_parent"
        android:layout_height="56dp" android:text="I'm Faculty"
        android:textSize="16sp" android:backgroundTint="#E91E63"/>
</LinearLayout>
